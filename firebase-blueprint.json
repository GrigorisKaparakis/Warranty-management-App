{
  "entities": {
    "Entry": {
      "title": "Warranty Entry",
      "description": "A warranty claim entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "warrantyId": { "type": "string" },
        "vin": { "type": "string" },
        "fullName": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["warrantyId", "vin", "fullName", "status", "createdAt"]
    },
    "AppError": {
      "title": "Application Error",
      "description": "Log of an application error",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "message": { "type": "string" },
        "url": { "type": "string" },
        "userAgent": { "type": "string" }
      },
      "required": ["timestamp", "message", "url", "userAgent"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "disabled": { "type": "boolean" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/entries/{entryId}": {
      "schema": "Entry",
      "description": "Collection of warranty entries"
    },
    "/errors/{errorId}": {
      "schema": "AppError",
      "description": "Collection of application error logs"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    }
  }
}
